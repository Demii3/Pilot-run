# Email Configuration
# Copy this file to .env and fill in your email service credentials

# Mail Driver: smtp, gmail, sendgrid, mailgun
MAIL_DRIVER=smtp

# SMTP Configuration (for generic SMTP servers like Mailtrap)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=tls

# Gmail Configuration
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-specific-password

# From Address
MAIL_FROM_ADDRESS=noreply@chengshi-construction.com
MAIL_FROM_NAME=Chengshi Construction Corp

# === SETUP INSTRUCTIONS ===

# Option 1: Using Mailtrap (Free, for testing)
# 1. Sign up at https://mailtrap.io
# 2. Create a project and get SMTP credentials
# 3. Copy this file to .env and fill in credentials

# Option 2: Using Gmail (Free)
# 1. Enable 2FA on your Gmail account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Set MAIL_DRIVER=gmail
# 4. Fill in GMAIL_EMAIL and GMAIL_APP_PASSWORD

# Option 3: Using SendGrid (Free tier available)
# 1. Sign up at https://sendgrid.com
# 2. Generate API key and SMTP credentials
# 3. Use SMTP configuration above

# Option 4: Using Mailgun (Free tier available)
# 1. Sign up at https://www.mailgun.com
# 2. Get SMTP credentials from dashboard
# 3. Use SMTP configuration above

# Option 5: Using local PHP mail()
# Leave MAIL_DRIVER as smtp with your server's SMTP settings
# Or configure PHP mail() in php.ini
